    affiliation: "Continental Reifen Deutschland GmbH"
    orcid: "https://orcid.org/0000-0001-8041-9538"
license: BSD-3-Clause
repository-code: "https://github.com/petlenz/tmech"
url: "https://tmech.readthedocs.io/"
keywords:
